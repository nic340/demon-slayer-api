CREATE TABLE actors (
    id INTEGER PRIMARY KEY,
    name TEXT
);

CREATE TABLE characters (
    id INTEGER PRIMARY KEY,
    name TEXT,
    breathing_style TEXT,
    rank TEXT,
    affiliation TEXT,
    actor_id INTEGER
);

